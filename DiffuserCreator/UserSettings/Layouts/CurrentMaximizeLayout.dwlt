    \"            if (_XRayCount <= 0 || _XRayCount > MAX_XRAY_COUNT) { return false;
    }\\r\\n\\r\\n            for (int i = 0; i < _XRayCount; i++)\\r\\n           
    {\\r\\n                if (isCutByXRaySide(worldPos, i))\\r\\n               
    {\\r\\n                    continue;\\r\\n                }\\r\\n\\r\\n               
    return true;\\r\\n            }\\r\\n\\r\\n            return false;\"\r\n}\r\n\r\n{\r\n   
